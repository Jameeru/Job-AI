# ═══════════════════════════════════════════════════════════
# Job AI — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it is in .gitignore.
# ═══════════════════════════════════════════════════════════

# ── Spring Profile ──────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Neon PostgreSQL ─────────────────────────────────────────
# Get from: https://console.neon.tech → Your Project → Connection Details
# Format: jdbc:postgresql://<host>/<dbname>?sslmode=require
DB_URL=jdbc:postgresql://ep-xxxxxx.ap-southeast-1.aws.neon.tech/jobai?sslmode=require
DB_USERNAME=jobai_user
DB_PASSWORD=your_neon_password_here

# ── Firebase ────────────────────────────────────────────────
# Project ID: Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to service account JSON:
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Place the JSON file in backend/src/main/resources/ for local dev
FIREBASE_SERVICE_ACCOUNT_PATH=classpath:firebase-service-account.json

# ── AWS / Amazon Bedrock ────────────────────────────────────
# Create IAM user with AmazonBedrockFullAccess policy
# Enable Claude Sonnet model in Bedrock console (Mumbai region recommended for India)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1

# Claude model to use for AI analysis, resume, and cover letter generation
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5

# ── CORS ────────────────────────────────────────────────────
# Local dev: allow Vite dev server
# Production: your Firebase Hosting URL (e.g., https://your-app.web.app)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Scheduler ───────────────────────────────────────────────
# Set to true in production to enable 7 AM daily job search
SCHEDULER_ENABLED=false
JOB_SEARCH_CRON=0 0 7 * * *

# ── Job Scraper ─────────────────────────────────────────────
# Minimum match score (0-10) to proceed with application
MIN_MATCH_SCORE=8
# Max jobs to collect per source per run
MAX_JOBS_PER_SOURCE=50
# Delay between requests to be polite to job sites (ms)
SCRAPER_DELAY_MS=2000

# ── Output Directories ──────────────────────────────────────
RESUME_OUTPUT_DIR=./generated/resumes
COVER_LETTER_OUTPUT_DIR=./generated/cover-letters
